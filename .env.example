# ============================================
# SPORTGUARD FRONTEND ENVIRONMENT VARIABLES
# ============================================

# Backend API Configuration
# Local development
VITE_API_BASE_URL=http://localhost:8000

# Production/Staging - Uncomment for deployment
# VITE_API_BASE_URL=https://api.sport-guard.vercel.app

# Vercel Deployment Configuration
# Set automatically by Vercel, no need to configure
VERCEL_ENV=production
VERCEL_URL=https://sport-guard.vercel.app

# Optional: API endpoints for specific services
# VITE_AUTH_API=http://localhost:8000/auth
# VITE_DETECTION_API=http://localhost:8000/api/detect
# VITE_ANALYTICS_API=http://localhost:8000/api/analytics
# VITE_UPLOAD_API=http://localhost:8000/api/upload

